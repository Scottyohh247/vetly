# Anthropic API Key
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# DVLA MOT History API Credentials
DVLA_MOT_API_KEY=your_dvla_mot_api_key_here
DVLA_CLIENT_ID=your_dvla_client_id_here
DVLA_CLIENT_SECRET=your_dvla_client_secret_here
DVLA_TOKEN_URL=https://dvla-api-token-url.example.com

# For development/testing - set to 'true' to use mock data
USE_MOCK_MOT_DATA=true
